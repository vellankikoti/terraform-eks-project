# Production Environment - Example terraform.tfvars
# Copy this file: cp terraform.tfvars.example terraform.tfvars
# IMPORTANT: Review ALL values before applying to production

aws_region   = "us-east-1"
environment  = "prod"
project_name = "myapp"

# VPC
vpc_cidr = "10.0.0.0/16"
az_count = 3

# EKS
cluster_version = "1.31"

# CRITICAL: Restrict API access to your VPN/office IPs
# public_access_cidrs = ["203.0.113.0/24", "198.51.100.0/24"]

# CloudWatch log retention
log_retention_days = 30

# CRITICAL: Set a strong password or use external secrets
# grafana_admin_password = "use-a-strong-password-here"

# Node Groups - Production layout with ON_DEMAND + SPOT
# The defaults are good for most setups. Override here if needed:
# node_groups = {
#   system = {
#     desired_size   = 3
#     max_size       = 4
#     min_size       = 3
#     instance_types = ["m5.large"]
#     capacity_type  = "ON_DEMAND"
#     disk_size      = 100
#     labels = {
#       "workload-type" = "system"
#       "node-role"     = "system"
#     }
#     taints = [{
#       key    = "CriticalAddonsOnly"
#       value  = "true"
#       effect = "PREFER_NO_SCHEDULE"
#     }]
#   }
#   general = {
#     desired_size   = 2
#     max_size       = 10
#     min_size       = 2
#     instance_types = ["m5.large", "m5a.large"]
#     capacity_type  = "ON_DEMAND"
#     disk_size      = 100
#     labels = {
#       "workload-type" = "general"
#     }
#   }
#   spot = {
#     desired_size   = 2
#     max_size       = 20
#     min_size       = 0
#     instance_types = ["t3.large", "t3a.large", "m5.large", "m5a.large", "m6i.large", "m6a.large"]
#     capacity_type  = "SPOT"
#     disk_size      = 50
#     labels = {
#       "workload-type" = "spot"
#       "lifecycle"     = "spot"
#     }
#   }
# }

# DNS & TLS (uncomment when you have Route53 hosted zones)
# route53_zone_ids            = ["Z1234567890ABC"]
# domain_filters              = ["example.com"]
# cert_manager_enable_route53 = true

# ArgoCD IRSA (enable if ArgoCD needs AWS API access)
# argocd_enable_irsa = true
