# Development Environment - Example terraform.tfvars
# Copy this file: cp terraform.tfvars.example terraform.tfvars
# Then customize values for your setup

aws_region   = "us-east-1"
environment  = "dev"
project_name = "myapp"

# VPC
vpc_cidr = "10.10.0.0/16"
az_count = 2

# EKS
cluster_version = "1.31"

