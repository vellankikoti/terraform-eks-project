# Staging Environment - Example terraform.tfvars
# Copy this file: cp terraform.tfvars.example terraform.tfvars
# Staging should mirror production at reduced scale

aws_region   = "us-east-1"
environment  = "staging"
project_name = "myapp"

# VPC
vpc_cidr = "10.20.0.0/16"
az_count = 2

# EKS
cluster_version = "1.31"
log_retention_days = 14

# DNS & TLS (uncomment when you have Route53 hosted zones)
# route53_zone_ids            = ["Z1234567890ABC"]
# cert_manager_enable_route53 = true
